*.pem
*.key
auth.json
**/auth.json
config.json
**/config.json
settings.json
settings.local.json
**/settings.local.json

# GitHub upload token used by github.sh (never commit)
.github_token

# Project-local TigerLiteCode state (per-machine config, model cache, history)
.tigercli/
.tigercli-file-history.json

